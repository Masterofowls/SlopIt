# ─────────────────────────────────────────────────────────────────────────────
# SlopIt — Environment variables (example)
#   Copy to `.env` and fill real values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-to-a-50-char-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.fly.dev
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,https://slopit.fly.dev
DJANGO_TIME_ZONE=UTC

# Frontend origin (CORS)
FRONTEND_URL=http://localhost:3000

# ─── Database (Supabase Postgres) ────────────────────────────────────────────
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://postgres:postgres@localhost:5432/slopit

# ─── Cache / Queue (Redis) ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── OAuth providers (legacy allauth — replaced by Clerk) ────────────────────
# These are no longer used for Google/GitHub OAuth. Kept for reference only.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_OAUTH_CLIENT_ID=
TELEGRAM_OAUTH_CLIENT_SECRET=

# ─── Clerk (OAuth — replaces allauth for Google + GitHub) ────────────────────
# Public values (safe to commit, also in fly.toml [env]):
CLERK_PUBLISHABLE_KEY=pk_test_cXVpY2stYnVsbGRvZy05MS5jbGVyay5hY2NvdW50cy5kZXYk
CLERK_FRONTEND_API_URL=https://quick-bulldog-91.clerk.accounts.dev
CLERK_JWKS_URL=https://quick-bulldog-91.clerk.accounts.dev/.well-known/jwks.json
# Secret — get from Clerk Dashboard → API Keys → Secret keys:
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# ─── Telegram Login Widget / OIDC ─────────────────────────────────────────────
# Public values (safe to commit, also in fly.toml [env]):
TELEGRAM_CLIENT_ID=8728778322
TELEGRAM_BOT_NAME=slopitbot
TELEGRAM_REDIRECT_URI=https://slopit-api.fly.dev/accounts/telegram/login/callback/
# Secrets — set with scripts/fly-set-telegram.ps1, never commit:
TELEGRAM_BOT_TOKEN=REPLACE_ME
TELEGRAM_CLIENT_SECRET=REPLACE_ME

# ─── Feed algorithm ──────────────────────────────────────────────────────────
# Default lifetime of a personal feed snapshot (hours, 10 ≤ x ≤ 48)
FEED_DEFAULT_LIFETIME_HOURS=10
FEED_MIN_LIFETIME_HOURS=10
FEED_MAX_LIFETIME_HOURS=48
# Page size for /api/feed
FEED_PAGE_SIZE=25

# ─── Storage (media uploads) ─────────────────────────────────────────────────
# Local in dev. In prod set to "s3" with Supabase S3-compatible bucket.
STORAGE_BACKEND=local
SUPABASE_S3_ENDPOINT=https://wrcfswfncrgcrhapblfl.storage.supabase.co/storage/v1/s3
SUPABASE_S3_BUCKET=slopit-media
SUPABASE_S3_ACCESS_KEY=a4c598c10f34ebf73ea43ac6ea9723d5


# ─── Observability ───────────────────────────────────────────────────────────
GLITCHTIP_DSN=

# ─── Maintenance mode ────────────────────────────────────────────────────────
MAINTENANCE_MODE=False
